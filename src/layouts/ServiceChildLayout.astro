---
import BaseLayout from './BaseLayout.astro';
import { site } from '../data/siteData.js';
const { parent, child, siblingServices, title, description, canonicalPath } = Astro.props;
const [, context, planning, cost, timing, outcome, communication, quality, inspection, priorities, estimate, local, comparison] = child.content;
const lead = `For ${child.name.toLowerCase()}, we start with the property: where the fence should run, what it needs to block or protect, how gates should work, and which material makes sense for the yard.`;
const phone = site.phone.replace(/\D/g, '');
---
<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <section class="hero compact">
    <img src="/images/hero.png" alt={child.name} />
    <div class="hero-copy">
      <p class="eyebrow">{parent.name}</p>
      <h1>{child.name} in Frederick, MD</h1>
      <p>{child.summary}</p>
      <div class="hero-actions"><a href="/contact/" class="btn">Request Service</a><a href={`tel:${phone}`} class="btn ghost">{site.phone}</a></div>
    </div>
  </section>

  <section class="service-snapshot">
    <div><span>01</span><strong>Walk The Line</strong><p>Review the fence run, grade, gates, access, and the problem the fence needs to solve.</p></div>
    <div><span>02</span><strong>Set The Scope</strong><p>Separate must-have layout decisions from optional upgrades, repairs, or material choices.</p></div>
    <div><span>03</span><strong>Install Cleanly</strong><p>Finish with straight runs, usable gates, tidy staging, and clear care guidance.</p></div>
  </section>

  <section class="section conversion-intro">
    <div class="intro-copy">
      <p class="eyebrow dark">Fence Service Planning</p>
      <h2>{child.name}: Layout, Materials, Access, And A Clear Next Step.</h2>
      <p class="lede">{lead}</p>
    </div>
    <aside class="estimate-card">
      <h3>Start With A Focused Local Review</h3>
      <ul>
        <li>Fence line and approximate length</li>
        <li>Privacy, safety, pet, pool, or boundary goal</li>
        <li>Gate locations, slope, and access</li>
        <li>HOA, neighbor, or permit concerns</li>
      </ul>
      <a href="/contact/" class="btn">Get The Next Step</a>
    </aside>
  </section>

  <section class="section modular-grid">
    <article class="feature-block wide">
      <h2>What We Check Before Recommending The Fence</h2>
      <p>{context}</p>
      <p>{local}</p>
    </article>
    <div class="feature-block">
      <h3>When To Call</h3>
      <ul class="check-list">{child.symptoms.map((item) => <li>{item}</li>)}</ul>
    </div>
    <div class="feature-block accent">
      <h3>What You Get</h3>
      <ul class="check-list">{child.benefits.map((item) => <li>{item}</li>)}</ul>
    </div>
  </section>

  <section class="section process-band">
    <div class="section-kicker">How The Work Moves</div>
    <h2>Our {child.name} Process</h2>
    <div class="steps enhanced">{child.process.map((step, i) => <div><span>{i + 1}</span><h3>{['Review','Scope','Execute','Wrap'][i] || 'Finish'}</h3><p>{step}</p></div>)}</div>
  </section>

  <section class="section content-modules">
    <div class="module-card"><h2>Plan The Fence Before Pricing It</h2><p>{planning}</p><p>{inspection}</p></div>
    <div class="module-card tinted"><h2>What Shapes The Estimate</h2><p>{cost}</p><p>{estimate}</p></div>
    <div class="module-card"><h2>Timing, Access, And Property Use</h2><p>{timing}</p><p>{communication}</p></div>
    <div class="module-card dark-card"><h2>Built To Hold Its Line</h2><p>{outcome}</p><p>{quality}</p></div>
  </section>

  <section class="conversion-strip">
    <div>
      <p class="eyebrow">Frederick Fence Planning</p>
      <h2>Need A Fast Answer On {child.name}?</h2>
      <p>{priorities}</p>
    </div>
    <a href="/contact/" class="btn light">Request Service</a>
  </section>

  <section class="section split">
    <article class="article-card">
      <h2>How To Compare Providers</h2>
      <p>{comparison}</p>
    </article>
    <aside class="panel sidebar-list">
      <h3>Good Estimates Should Clarify</h3>
      <ul>
        <li>What is included and excluded</li>
        <li>How access or season affects timing</li>
        <li>Which items are urgent</li>
        <li>How the finished result will be reviewed</li>
      </ul>
    </aside>
  </section>

  <section class="section muted">
    <h2>Questions About {child.name}</h2>
    <div class="faq-grid">{child.faqs.map((faq) => <details><summary>{faq.question}</summary><p>{faq.answer}</p></details>)}</div>
  </section>

  <section class="section">
    <h2>Related {parent.name} Services</h2>
    <div class="cards small">{siblingServices.slice(0, 4).map((sibling) => <a class="card" href={`/services/${parent.slug}/${sibling.slug}/`}><h3>{sibling.name}</h3><p>{sibling.summary}</p></a>)}</div>
  </section>
</BaseLayout>
