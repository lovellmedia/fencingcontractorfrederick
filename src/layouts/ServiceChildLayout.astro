---
import BaseLayout from './BaseLayout.astro';
import { site } from '../data/siteData.js';
import { getChildCopy } from '../data/editorialCopy.js';
const { parent, child, siblingServices, title, description, canonicalPath } = Astro.props;
const copy = getChildCopy(parent, child);
const phone = site.phone.replace(/\D/g, '');
---
<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <section class="hero compact">
    <img src="/images/hero.png" alt={child.name} />
    <div class="hero-copy">
      <p class="eyebrow">{parent.name}</p>
      <h1>{child.name} in Frederick, MD</h1>
      <p>{copy.card}</p>
      <div class="hero-actions"><a href="/contact/" class="btn">Request Service</a><a href={`tel:${phone}`} class="btn ghost">{site.phone}</a></div>
    </div>
  </section>

  <section class="service-snapshot">
    <div><span>01</span><strong>Walk The Line</strong><p>Review the fence run, grade, gates, access, and the problem the fence needs to solve.</p></div>
    <div><span>02</span><strong>Set The Scope</strong><p>Separate must-have layout decisions from optional upgrades, repairs, or material choices.</p></div>
    <div><span>03</span><strong>Install Cleanly</strong><p>Finish with straight runs, usable gates, tidy staging, and clear care guidance.</p></div>
  </section>

  <section class="section conversion-intro">
    <div class="intro-copy">
      <p class="eyebrow dark">Fence Planning</p>
      <h2>{child.name}: Layout, Materials, Access, And A Fence That Makes Sense.</h2>
      <p class="lede">{copy.lead}</p>
    </div>
    <aside class="estimate-card">
      <h3>Tell Us What The Fence Needs To Do</h3>
      <ul>
        <li>Fence line and approximate length</li>
        <li>Privacy, safety, pet, pool, or boundary goal</li>
        <li>Gate locations, slope, and access</li>
        <li>HOA, neighbor, or permit concerns</li>
      </ul>
      <a href="/contact/" class="btn">Get The Next Step</a>
    </aside>
  </section>

  <section class="section modular-grid">
    <article class="feature-block wide">
      <h2>What We Check Before Recommending The Fence</h2>
      <p>{copy.checks}</p>
      <p>{copy.details}</p>
    </article>
    <div class="feature-block">
      <h3>When To Call</h3>
      <ul class="check-list">{copy.symptoms.map((item) => <li>{item}</li>)}</ul>
    </div>
    <div class="feature-block accent">
      <h3>What You Get</h3>
      <ul class="check-list">{copy.benefits.map((item) => <li>{item}</li>)}</ul>
    </div>
  </section>

  <section class="section process-band">
    <div class="section-kicker">What Happens Next</div>
    <h2>Our {child.name} Process</h2>
    <div class="steps enhanced">{copy.process.map((step, i) => <div><span>{i + 1}</span><h3>{['Review','Scope','Build','Walkthrough'][i] || 'Finish'}</h3><p>{step}</p></div>)}</div>
  </section>

  <section class="section content-modules">
    <div class="module-card"><h2>What We Decide Before We Price It</h2><p>{copy.purpose}</p><p>We want the fence decision to feel practical: where it runs, how tall it should be, what material fits the home, and which gate locations will make the yard easier to use.</p></div>
    <div class="module-card tinted"><h2>What Shapes The Estimate</h2><p>{copy.estimate}</p></div>
    <div class="module-card"><h2>Timing, Access, And Property Use</h2><p>{copy.timing}</p></div>
    <div class="module-card dark-card"><h2>Built To Hold Its Line</h2><p>{copy.result}</p></div>
  </section>

  <section class="conversion-strip">
    <div>
      <p class="eyebrow">Frederick Fence Planning</p>
      <h2>Want Help With {child.name}?</h2>
      <p>Send the fence goal, a few photos if you have them, and anything you already know about gates, property lines, HOA rules, pets, pools, or repair concerns. We will help you sort the next step.</p>
    </div>
    <a href="/contact/" class="btn light">Request Service</a>
  </section>

  <section class="section split">
    <article class="article-card">
      <h2>How To Compare Providers</h2>
      <p>{copy.compare}</p>
    </article>
    <aside class="panel sidebar-list">
      <h3>A Useful Fence Estimate Should Show</h3>
      <ul>
        <li>The proposed line, height, material, post plan, and gate locations</li>
        <li>How access, slope, removal, utilities, or HOA rules affect timing</li>
        <li>Which decisions are required now and which upgrades are optional</li>
        <li>How alignment, gate movement, cleanup, and care will be reviewed</li>
      </ul>
    </aside>
  </section>

  <section class="section muted">
    <h2>Questions About {child.name}</h2>
    <div class="faq-grid">{copy.faqs.map((faq) => <details><summary>{faq.question}</summary><p>{faq.answer}</p></details>)}</div>
  </section>

  <section class="section">
    <h2>Related {parent.name} Services</h2>
    <div class="cards small">{siblingServices.slice(0, 4).map((sibling) => <a class="card" href={`/services/${parent.slug}/${sibling.slug}/`}><h3>{sibling.name}</h3><p>{getChildCopy(parent, sibling).card}</p></a>)}</div>
  </section>
</BaseLayout>
