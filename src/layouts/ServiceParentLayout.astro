---
import BaseLayout from './BaseLayout.astro';
import { site } from '../data/siteData.js';
import { getFamilyCopy, getChildCopy } from '../data/editorialCopy.js';
const { parent, childServices, title, description, canonicalPath } = Astro.props;
const familyCopy = getFamilyCopy(parent);
---
<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <section class="hero compact">
    <img src="/images/hero.png" alt={site.business} />
    <div class="hero-copy"><p class="eyebrow">{site.category} in Frederick</p><h1>{parent.name} in Frederick, MD</h1><p>{familyCopy.card}</p><a href="/contact/" class="btn">Plan My Project</a></div>
  </section>
  <section class="section split">
    <div>
      <h2>How We Plan {parent.name}</h2>
      <p>{familyCopy.lead}</p>
      <p>We do not start with a generic fence package. We start with the way the property is used: where people walk, where pets run, where neighbors sit, where the grade changes, and where a gate would make the yard easier to live with.</p>
      <p>By the time we price the work, you should understand the layout, the material choices, the likely timing, and which details need to be settled before installation or repair begins.</p>
    </div>
    <aside class="panel">
      <h3>What We Check</h3>
      <p>{familyCopy.checks}</p>
      <p>We also look at utilities, old posts, removal needs, drainage, property access, and any HOA, pool, neighbor, or permit question that could change the scope.</p>
    </aside>
  </section>
  <section class="section"><h2>{parent.name} services</h2><div class="cards">{childServices.map((child) => <a class="card" href={`/services/${parent.slug}/${child.slug}/`}><h3>{child.name}</h3><p>{getChildCopy(parent, child).card}</p></a>)}</div></section>
  <section class="cta"><h2>Ready to talk through the fence line?</h2><p>Tell us what the fence needs to solve and we will help map layout, materials, gates, timing, access, and the next right step.</p><a href="/contact/" class="btn light">Request Service</a></section>
</BaseLayout>
