---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, serviceFamilies } from '../data/siteData.js';
import { getFamilyCopy } from '../data/editorialCopy.js';
---
<BaseLayout title={'Resources | ' + site.title} description={'Frederick service planning resources from ' + site.business + '.'} canonicalPath="/resources/">
  <section class="page-head"><h1>Frederick Fence Resources</h1><p>Planning guidance for privacy, pets, pools, repairs, gates, materials, sloped yards, HOA approvals, and property-specific fence decisions.</p></section>
  <section class="section"><div class="cards">{serviceFamilies.map((family) => <a class="card" href={`/services/${family.slug}/`}><h3>{family.name}</h3><p>{getFamilyCopy(family).card}</p></a>)}</div></section>
</BaseLayout>
