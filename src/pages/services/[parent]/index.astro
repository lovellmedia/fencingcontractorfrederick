---
import ServiceParentLayout from '../../../layouts/ServiceParentLayout.astro';
import { serviceFamilies, makeServiceTitle } from '../../../data/siteData.js';
import { getFamilyCopy } from '../../../data/editorialCopy.js';
export function getStaticPaths() { return serviceFamilies.map((parent) => ({ params: { parent: parent.slug }, props: { parent } })); }
const { parent } = Astro.props;
const copy = getFamilyCopy(parent);
---
<ServiceParentLayout title={makeServiceTitle(parent.name)} description={copy.card} parent={parent} childServices={parent.children} canonicalPath={`/services/${parent.slug}/`} />
