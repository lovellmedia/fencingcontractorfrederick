---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site, serviceFamilies } from '../../data/siteData.js';
import { getFamilyCopy } from '../../data/editorialCopy.js';
---
<BaseLayout title={'Services | ' + site.title} description={'All services from ' + site.business + ' in Frederick, Maryland.'} canonicalPath="/services/">
  <section class="page-head"><h1>{site.business} Services</h1><p>Start with the reason you need the fence, then choose the service path that best matches the property. We help with new installation, repair, gates, specialty fencing, and Frederick-specific site constraints.</p></section>
  <section class="section"><div class="cards">{serviceFamilies.map((family) => <a class="card" href={`/services/${family.slug}/`}><h3>{family.name}</h3><p>{getFamilyCopy(family).card}</p></a>)}</div></section>
</BaseLayout>
