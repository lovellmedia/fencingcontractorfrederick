---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, serviceFamilies } from '../data/siteData.js';
import { getFamilyCopy } from '../data/editorialCopy.js';
---
<BaseLayout title={'Blog | ' + site.title} description={'Local Frederick planning notes from ' + site.business + '.'} canonicalPath="/blog/">
  <section class="page-head"><h1>{site.business} Blog</h1><p>Short local notes on fence lines, privacy decisions, gates, repairs, materials, HOA questions, and choosing the right scope before installation starts.</p></section>
  <section class="section"><div class="cards">{serviceFamilies.map((family) => <a class="card" href={`/services/${family.slug}/`}><h3>How we plan {family.name.toLowerCase()} in Frederick</h3><p>{getFamilyCopy(family).card}</p></a>)}</div></section>
</BaseLayout>
